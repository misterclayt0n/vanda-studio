---
import vandaAppIconUrl from "@vanda-studio/ui/assets/vanda-app-icon.svg?url";
import vandaMarkUrl from "@vanda-studio/ui/assets/vanda-mark.svg?url";
import "../styles.css";

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={vandaAppIconUrl} />
		<title>{title} — Vanda Studio</title>
	</head>
	<body>
		<header class="site-header">
			<nav class="nav-shell" aria-label="Principal">
				<a class="brand" href="/" aria-label="Vanda Studio">
					<img src={vandaMarkUrl} alt="" width="24" height="24" />
					<span>Vanda Studio</span>
				</a>
				<a class="button button-ghost button-small" href="https://app.vandastudio.app">Entrar</a>
			</nav>
		</header>
		<main class="legal-shell">
			<slot />
		</main>
		<footer class="legal-footer">
			<a href="/privacy">Privacidade</a>
			<a href="/terms">Termos</a>
			<a href="mailto:hello@vandastudio.app">Contato</a>
		</footer>
	</body>
</html>

<style>
	.legal-shell { width: min(760px, calc(100% - 40px)); margin: 0 auto; padding: 132px 0 72px; }
	.legal-shell :global(h1) { font-size: clamp(2rem, 5vw, 3.25rem); margin: 0 0 12px; }
	.legal-shell :global(h2) { font-size: 1.25rem; margin: 40px 0 10px; }
	.legal-shell :global(p), .legal-shell :global(li) { color: var(--text-secondary); line-height: 1.7; }
	.legal-shell :global(ul) { padding-left: 20px; }
	.legal-shell :global(a), .legal-footer a { color: var(--brand-accent); }
	.legal-shell :global(.updated) { color: var(--text-muted); font-size: .875rem; margin-bottom: 36px; }
	.legal-footer { display: flex; justify-content: center; gap: 24px; padding: 28px 20px; border-top: 1px solid var(--border); font-size: .875rem; }
</style>
