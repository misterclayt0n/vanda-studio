{
  "name": "@vanda-studio/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:vanda": "pnpm --filter @vanda-studio/vanda dev",
    "dev:landing": "pnpm --filter @vanda-studio/landing dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint --ignore-pattern '**/node_modules/**' --ignore-pattern '**/dist/**' --ignore-pattern '**/.output/**' .",
    "lint:fix": "oxlint --ignore-pattern '**/node_modules/**' --ignore-pattern '**/dist/**' --ignore-pattern '**/.output/**' . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "clean": "turbo run clean && rm -rf node_modules .turbo apps/*/dist apps/*/.output packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@11.7.0"
}
